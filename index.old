        <!-- SLIDE 6 – LA APORÍA DEL TIEMPO Y EL PUENTE -->
        <div class="slide" data-slide="6">
            <div style="max-width: 1300px; width: 100%; padding: 1rem;">
                <h2 class="section-title gradient-text"
                    style="text-align: center; margin-bottom: 2rem; font-size: clamp(1.8rem, 5vw, 2.5rem);">
                    La Aporía del Tiempo y su Resolución
                </h2>
                <div
                    style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.8rem; margin-bottom: 1rem;">
                    <div
                        style="background: rgba(59,130,246,0.08); backdrop-filter: blur(4px); border-radius: 24px; padding: 1.5rem; border-left: 6px solid #3b82f6; box-shadow: 0 6px 14px rgba(0,0,0,0.2);">
                        <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
                            <img src="imagenes/agustin.png" alt="San Agustín"
                                style="width: 60px; height: 60px; border-radius: 50%; object-fit: cover; border: 3px solid #60a5fa; box-shadow: 0 0 15px rgba(96,165,250,0.5);">
                            <h3 style="color: #60a5fa; font-size: 1.5rem; font-weight: 700; margin: 0;">LA APORÍA DEL
                                TIEMPO EN AGUSTÍN</h3>
                        </div>
                        <p
                            style="color: #e2e8f0; font-size: 1rem; line-height: 1.5; margin-bottom: 0.8rem; font-style: italic;">
                            “Pasado ya no es, futuro aún no es” — ¿cómo medir lo que no existe?</p>
                        <p style="color: #cbd5e1; font-size: 0.95rem; line-height: 1.5;">
                            <strong style="color: #60a5fa;">Solución subjetiva:</strong> El tiempo existe en el
                            alma.<br>
                            <span style="color: #94a3b8;">Pasado = memoria / Futuro = expectación / Presente =
                                atención.</span><br>
                            <strong style="color: #60a5fa;">Consecuencia:</strong> El tiempo solo es accesible mediante
                            el relato interior.
                        </p>
                    </div>
                    <div
                        style="background: rgba(139,92,246,0.08); backdrop-filter: blur(4px); border-radius: 24px; padding: 1.5rem; border-left: 6px solid #8b5cf6; box-shadow: 0 6px 14px rgba(0,0,0,0.2);">
